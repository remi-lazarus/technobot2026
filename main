  analogWrite(6,60);
  digitalWrite(5,HIGH);
  digitalWrite(7,LOW);
  analogWrite(3,60);
  digitalWrite(2,HIGH);
  digitalWrite(4,LOW);
}

void avanttoute(){
  analogWrite(6,255);
  digitalWrite(5,HIGH);
  digitalWrite(7,LOW);
  analogWrite(3,255);
  digitalWrite(2,LOW);
  digitalWrite(4,HIGH);
}

void arrieredroite(){
  analogWrite(6,255);
  digitalWrite(5,LOW);
  digitalWrite(7,HIGH);
  analogWrite(3,0);
  digitalWrite(2,HIGH);
  digitalWrite(4,LOW);
}

void avant150(){
  analogWrite(6,150);
  digitalWrite(5,HIGH);
  digitalWrite(7,LOW);
  analogWrite(3,150);
  digitalWrite(2,LOW);
  digitalWrite(4,HIGH);
}

void arrieregauche(){
  analogWrite(6,0);
  digitalWrite(5,LOW);
  digitalWrite(7,HIGH);
  analogWrite(3,255);
  digitalWrite(2,HIGH);
  digitalWrite(4,LOW);
}
